---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "The definitive cycling guide to the Oisans region. Routes, GPX files, and everything you need to ride Alpe d'Huez and beyond.", image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | bend7</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  {image && <meta property="og:image" content={image} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <!-- Prevent FOUC for dark mode -->
  <script is:inline>
    if (localStorage.getItem('theme') === 'dark' || (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }
  </script>
</head>
<body>

  <!-- Header -->
  <header class="sticky top-0 z-50 border-b border-surface-200 bg-white/80 backdrop-blur-xl dark:border-dark-border dark:bg-dark-bg/80">
    <div class="mx-auto max-w-wide px-4 sm:px-6 lg:px-8">
      <div class="flex h-16 items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-baseline gap-0.5 text-xl font-bold tracking-tight">
          <span class="text-surface-900 dark:text-white">bend</span><span class="text-brand-600 dark:text-brand-400">7</span>
        </a>

        <!-- Nav -->
        <nav class="hidden items-center gap-8 md:flex">
          <a href="/routes" class="text-body-md font-medium text-surface-600 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">Routes</a>

          <!-- Plan your trip dropdown -->
          <div class="relative" id="plan-nav">
            <button
              id="plan-trigger"
              aria-haspopup="true"
              aria-expanded="false"
              class="flex items-center gap-1 text-body-md font-medium text-surface-600 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors"
            >
              Plan your trip
              <svg id="plan-chevron" class="h-4 w-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>

            <div
              id="plan-panel"
              role="menu"
              class="pointer-events-none absolute left-1/2 top-full z-50 w-72 -translate-x-1/2 pt-3 opacity-0 transition-all duration-200"
            >
              <div class="rounded-2xl border border-surface-200 bg-white shadow-xl dark:border-dark-border dark:bg-dark-card p-2">

                <a href="/plan/where-to-stay" role="menuitem" class="flex items-start gap-3 rounded-xl p-3 hover:bg-surface-50 dark:hover:bg-surface-800 transition-colors">
                  <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600 dark:bg-brand-900/30 dark:text-brand-400">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                  </div>
                  <div>
                    <p class="text-body-sm font-semibold text-surface-900 dark:text-white">Where to stay</p>
                    <p class="mt-0.5 text-body-xs text-surface-500 dark:text-surface-400">Hotels, chalets and camping in the valley</p>
                  </div>
                </a>

                <a href="/plan/bike-rental" role="menuitem" class="flex items-start gap-3 rounded-xl p-3 hover:bg-surface-50 dark:hover:bg-surface-800 transition-colors">
                  <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600 dark:bg-brand-900/30 dark:text-brand-400">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/><circle cx="5" cy="17" r="3"/><circle cx="19" cy="17" r="3"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M5 17l3-7h8l3 7"/></svg>
                  </div>
                  <div>
                    <p class="text-body-sm font-semibold text-surface-900 dark:text-white">Bike rental</p>
                    <p class="mt-0.5 text-body-xs text-surface-500 dark:text-surface-400">Find the right bike for your climb</p>
                  </div>
                </a>

                <a href="/plan/getting-here" role="menuitem" class="flex items-start gap-3 rounded-xl p-3 hover:bg-surface-50 dark:hover:bg-surface-800 transition-colors">
                  <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600 dark:bg-brand-900/30 dark:text-brand-400">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  </div>
                  <div>
                    <p class="text-body-sm font-semibold text-surface-900 dark:text-white">Getting here</p>
                    <p class="mt-0.5 text-body-xs text-surface-500 dark:text-surface-400">Transfers, trains and driving directions</p>
                  </div>
                </a>

                <a href="/plan/when-to-visit" role="menuitem" class="flex items-start gap-3 rounded-xl p-3 hover:bg-surface-50 dark:hover:bg-surface-800 transition-colors">
                  <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-600 dark:bg-brand-900/30 dark:text-brand-400">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  </div>
                  <div>
                    <p class="text-body-sm font-semibold text-surface-900 dark:text-white">When to visit</p>
                    <p class="mt-0.5 text-body-xs text-surface-500 dark:text-surface-400">Season guide and weather tips</p>
                  </div>
                </a>

              </div>
            </div>
          </div>

          <a href="/blog" class="text-body-md font-medium text-surface-600 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">Stories</a>
          <a href="/about" class="text-body-md font-medium text-surface-600 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">About</a>
        </nav>

        <!-- Right side: theme toggle + CTA -->
        <div class="flex items-center gap-3">
          <!-- Dark mode toggle — Dockit style -->
          <button id="theme-toggle" class="rounded-xl border border-surface-200 p-2 text-surface-500 hover:bg-surface-100 dark:border-dark-border dark:text-surface-400 dark:hover:bg-surface-800 transition-colors" aria-label="Toggle theme">
            <svg class="h-5 w-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
            <svg class="h-5 w-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          </button>

          <a href="/newsletter" class="btn-primary hidden sm:inline-flex">Get free routes</a>

          <!-- Mobile menu button -->
          <button class="md:hidden rounded-xl border border-surface-200 p-2 text-surface-600 dark:border-dark-border dark:text-surface-400" id="mobile-menu-btn" aria-label="Menu">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="hidden border-t border-surface-200 bg-white px-4 pb-4 pt-2 dark:border-dark-border dark:bg-dark-bg md:hidden" id="mobile-menu">
      <nav class="flex flex-col gap-1">
        <a href="/routes" class="rounded-xl px-3 py-2.5 text-body-md font-medium text-surface-700 hover:bg-surface-50 dark:text-surface-300 dark:hover:bg-surface-800">Routes</a>
        <a href="/plan" class="rounded-xl px-3 py-2.5 text-body-md font-medium text-surface-700 hover:bg-surface-50 dark:text-surface-300 dark:hover:bg-surface-800">Plan your trip</a>
        <a href="/blog" class="rounded-xl px-3 py-2.5 text-body-md font-medium text-surface-700 hover:bg-surface-50 dark:text-surface-300 dark:hover:bg-surface-800">Stories</a>
        <a href="/about" class="rounded-xl px-3 py-2.5 text-body-md font-medium text-surface-700 hover:bg-surface-50 dark:text-surface-300 dark:hover:bg-surface-800">About</a>
        <div class="mt-3">
          <a href="/newsletter" class="btn-primary w-full justify-center">Get free routes</a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-surface-200 bg-surface-50 dark:border-dark-border dark:bg-dark-card">
    <div class="mx-auto max-w-wide px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-8 py-16 md:grid-cols-4 lg:grid-cols-6">
        <div class="col-span-2">
          <a href="/" class="flex items-baseline gap-0.5 text-xl font-bold tracking-tight">
            <span class="text-surface-900 dark:text-white">bend</span><span class="text-brand-600 dark:text-brand-400">7</span>
          </a>
          <p class="mt-4 max-w-xs text-body-sm text-surface-500 dark:text-surface-400">
            The definitive cycling guide to the Oisans region. Written from the saddle by someone who lives here.
          </p>
        </div>
        <div>
          <h4 class="text-body-sm font-semibold text-surface-900 dark:text-white mb-4">Routes</h4>
          <ul class="space-y-3">
            <li><a href="/routes/alpe-dhuez" class="text-body-sm text-surface-500 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">Alpe d'Huez</a></li>
            <li><a href="/routes/col-du-galibier" class="text-body-sm text-surface-500 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">Col du Galibier</a></li>
            <li><a href="/routes/croix-de-fer" class="text-body-sm text-surface-500 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">Croix de Fer</a></li>
            <li><a href="/routes" class="text-body-sm text-surface-500 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">All routes</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-body-sm font-semibold text-surface-900 dark:text-white mb-4">Plan</h4>
          <ul class="space-y-3">
            <li><a href="/plan/where-to-stay" class="text-body-sm text-surface-500 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">Where to stay</a></li>
            <li><a href="/plan/bike-rental" class="text-body-sm text-surface-500 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">Bike rental</a></li>
            <li><a href="/plan/getting-here" class="text-body-sm text-surface-500 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">Getting here</a></li>
            <li><a href="/plan/when-to-visit" class="text-body-sm text-surface-500 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">When to visit</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-body-sm font-semibold text-surface-900 dark:text-white mb-4">Connect</h4>
          <ul class="space-y-3">
            <li><a href="https://instagram.com/bend7" target="_blank" class="text-body-sm text-surface-500 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">Instagram</a></li>
            <li><a href="https://strava.com/clubs/bend7" target="_blank" class="text-body-sm text-surface-500 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">Strava Club</a></li>
            <li><a href="/newsletter" class="text-body-sm text-surface-500 hover:text-surface-900 dark:text-surface-400 dark:hover:text-white transition-colors">Newsletter</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-surface-200 dark:border-dark-border py-8">
        <p class="text-body-sm text-surface-500 dark:text-surface-400">&copy; {new Date().getFullYear()} bend7. All rights reserved. Made from Le Cert, Auris-en-Oisans.</p>
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });

    // Plan your trip dropdown
    (() => {
      const nav = document.getElementById('plan-nav');
      const panel = document.getElementById('plan-panel');
      const chevron = document.getElementById('plan-chevron');
      const trigger = document.getElementById('plan-trigger');
      if (!nav || !panel || !chevron || !trigger) return;

      let closeTimer: ReturnType<typeof setTimeout>;

      function open() {
        clearTimeout(closeTimer);
        panel.classList.remove('opacity-0', 'pointer-events-none');
        panel.classList.add('opacity-100');
        chevron.classList.add('rotate-180');
        trigger.setAttribute('aria-expanded', 'true');
      }

      function close() {
        closeTimer = setTimeout(() => {
          panel.classList.add('opacity-0', 'pointer-events-none');
          panel.classList.remove('opacity-100');
          chevron.classList.remove('rotate-180');
          trigger.setAttribute('aria-expanded', 'false');
        }, 120);
      }

      nav.addEventListener('mouseenter', open);
      nav.addEventListener('mouseleave', close);
      panel.addEventListener('mouseenter', () => clearTimeout(closeTimer));
      panel.addEventListener('mouseleave', close);

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    })();

    // Dark mode toggle
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const html = document.documentElement;
      if (html.classList.contains('dark')) {
        html.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        html.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  </script>
</body>
</html>
